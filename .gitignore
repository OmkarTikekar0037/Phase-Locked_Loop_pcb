# =========================
# KiCad Ignore Rules
# =========================

# Autosave & backup files
*-autosave*
#auto_saved_files#
*.bak
*.tmp

# Cache files
fp-info-cache
*.kicad_prl
*.kicad_pcb-bak
*.kicad_sch-bak

# Lock files
*.lck

# Plot / fabrication outputs (optional — keep if you want versioned outputs)
*.gbr
*.gerber
*.drl
*.d356
*.pos
*.rpt
*.csv
*.step
*.stp

# Netlists (usually regenerated)
*.net

# Simulation files
*.sim
*.raw

# Temporary / editor files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python cache (if using scripts/plugins)
__pycache__/
*.pyc

# Logs
*.log

# =========================
# Optional: Backup folders
# =========================
*-backups/
backup/
backups/